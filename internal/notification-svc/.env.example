SERVICE_NAME=notification
SERVICE_ENV=local

POSTGRES_DB=notification
POSTGRES_USER=notification
POSTGRES_PASSWORD=notification
POSTGRES_SSLMODE=disable

ORDER_EVENTS_ENABLED=true
ORDER_EVENTS_TOPIC=order.events
ORDER_EVENTS_GROUP_ID=notification-svc-order-events-v1
ORDER_EVENTS_POLL_INTERVAL=500ms

LOG_LEVEL=debug

OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_INTERVAL=500ms
OUTBOX_RELAY_RETRY_BASE_BACKOFF=1s
OUTBOX_RELAY_RETRY_MAX_BACKOFF=30s
OUTBOX_RELAY_WORKER_ID=notification-svc-relay-1
OUTBOX_RELAY_STALE_LOCK_TTL=30s
