SERVICE_NAME=order
SERVICE_ENV=local
SERVICE_HTTP_ADDR=:8080
SERVICE_GRPC_ADDR=:9090

POSTGRES_HOST=order-postgres
POSTGRES_PORT=5432
POSTGRES_DB=order
