SERVICE_NAME=payment-svc
SERVICE_ENV=local
SERVICE_HTTP_ADDR=:18085
SERVICE_GRPC_ADDR=:19095

POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_DB=payment
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_SSLMODE=disable

KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

LOG_LEVEL=debug

OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_INTERVAL=500ms
OUTBOX_RELAY_RETRY_BASE_BACKOFF=1s
OUTBOX_RELAY_RETRY_MAX_BACKOFF=30s
OUTBOX_RELAY_WORKER_ID=payment-svc-relay-1
OUTBOX_RELAY_STALE_LOCK_TTL=30s
