SERVICE_NAME=product-svc
SERVICE_ENV=local
SERVICE_HTTP_ADDR=:8080
SERVICE_GRPC_ADDR=:9090

POSTGRES_HOST=product-postgres
POSTGRES_PORT=5432
POSTGRES_DB=product
POSTGRES_USER=product
POSTGRES_PASSWORD=product
POSTGRES_SSLMODE=disable

KAFKA_BROKERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true

LOG_LEVEL=debug

OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_INTERVAL=500ms
OUTBOX_RELAY_RETRY_BASE_BACKOFF=1s
OUTBOX_RELAY_RETRY_MAX_BACKOFF=30s
OUTBOX_RELAY_WORKER_ID=product-svc-relay-1
OUTBOX_RELAY_STALE_LOCK_TTL=30s
