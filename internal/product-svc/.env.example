SERVICE_NAME=product-svc
SERVICE_ENV=local

POSTGRES_DB=catalog
POSTGRES_USER=catalog
POSTGRES_PASSWORD=catalog
POSTGRES_SSLMODE=disable

AUTH_ACCESS_TOKEN_KEY=local-dev-access-token-key
AUTH_ACCESS_TOKEN_ISSUER=ecom-identity-svc

LOG_LEVEL=debug

OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_INTERVAL=500ms
OUTBOX_RELAY_RETRY_BASE_BACKOFF=1s
OUTBOX_RELAY_RETRY_MAX_BACKOFF=30s
OUTBOX_RELAY_WORKER_ID=product-svc-relay-1
OUTBOX_RELAY_STALE_LOCK_TTL=30s
