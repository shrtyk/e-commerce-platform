SERVICE_NAME=identity-svc
SERVICE_ENV=local

POSTGRES_DB=identity
POSTGRES_USER=identity
POSTGRES_PASSWORD=identity
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m
POSTGRES_CONN_MAX_IDLETIME=1m

AUTH_SESSION_TTL=168h
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_ACCESS_TOKEN_KEY=local-dev-access-token-key
AUTH_ACCESS_TOKEN_ISSUER=ecom-identity-svc

BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_DISPLAY_NAME=Bootstrap Admin

LOG_LEVEL=debug
